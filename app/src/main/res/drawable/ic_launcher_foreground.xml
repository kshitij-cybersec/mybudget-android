<vector xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:aapt="http://schemas.android.com/aapt"
    android:width="108dp"
    android:height="108dp"
    android:viewportWidth="108"
    android:viewportHeight="108">

    <!-- Wallet/card shape - rounded rectangle -->
    <path
        android:pathData="M30,38h48c3,0 5,2 5,5v22c0,3 -2,5 -5,5h-48c-3,0 -5,-2 -5,-5v-22c0,-3 2,-5 5,-5z"
        android:fillColor="#FFFFFF" />

    <!-- Card stripe -->
    <path
        android:pathData="M25,47h58v5h-58z">
        <aapt:attr name="android:fillColor">
            <gradient
                android:startX="25"
                android:startY="49"
                android:endX="83"
                android:endY="49"
                android:type="linear">
                <item android:color="#FF6C5CE7" android:offset="0.0" />
                <item android:color="#FF00CEC9" android:offset="1.0" />
            </gradient>
        </aapt:attr>
    </path>

    <!-- Rupee/Currency symbol -->
    <path
        android:pathData="M44,57h3v1.5h-3zM44,60h3v1.5h-3zM46,57l4,7h-2l-4,-7zM44,57h7v1.5h-7z"
        android:fillColor="#6C5CE7" />

    <!-- Coin circle -->
    <path
        android:pathData="M64,58m-6,0a6,6 0,1 1,12 0a6,6 0,1 1,-12 0">
        <aapt:attr name="android:fillColor">
            <gradient
                android:centerX="64"
                android:centerY="58"
                android:gradientRadius="6"
                android:type="radial">
                <item android:color="#FF00E676" android:offset="0.0" />
                <item android:color="#FF00CEC9" android:offset="1.0" />
            </gradient>
        </aapt:attr>
    </path>

    <!-- Dollar/currency mark inside coin -->
    <path
        android:pathData="M63.5,55v6M62,56.5h3c0.8,0 1.5,0.5 1.5,1s-0.7,1 -1.5,1h-3c-0.8,0 -1.5,0.5 -1.5,1s0.7,1 1.5,1h3"
        android:strokeWidth="0.8"
        android:strokeColor="#FFFFFF"
        android:fillColor="#00000000" />

    <!-- Upward trend arrow -->
    <path
        android:pathData="M34,42l6,-4l6,2l10,-6"
        android:strokeWidth="1.8"
        android:strokeColor="#00E676"
        android:fillColor="#00000000"
        android:strokeLineCap="round"
        android:strokeLineJoin="round" />

    <!-- Arrow tip -->
    <path
        android:pathData="M53,34l3,0l0,3"
        android:strokeWidth="1.8"
        android:strokeColor="#00E676"
        android:fillColor="#00000000"
        android:strokeLineCap="round"
        android:strokeLineJoin="round" />
</vector>